{
  "name": "claude-monitor",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["src/server", "src/client"],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w src/server\" \"npm run dev -w src/client\"",
    "build": "npm run build -w src/client",
    "start": "npm run start -w src/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
